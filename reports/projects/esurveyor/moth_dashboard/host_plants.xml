<?xml version="1.0" encoding="UTF-8"?>
<report
  title="e-Surveyor: Host plants"
  description="Report for a user's species data host plants in e-Surveyor">

  <query>
    SELECT #columns#
    FROM cache_occurrences_functional o
    JOIN cache_taxa_taxon_lists cttl ON cttl.id=o.preferred_taxa_taxon_list_id
    LEFT JOIN esurveyor.moth_traits mt ON mt.tvk=cttl.external_key
    #joins#
    WHERE o.survey_id=#survey_id#
  </query>
  <order_bys>
    <order_by>3 desc</order_by>
  </order_bys>
  <params>
    <param name="survey_id" display="Survey ID" datatype="integer" />
    <param name="user_id" display="User ID" datatype="integer" default="">
      <where>o.created_by_id=#user_id#</where>
    </param>
    <param name="site_name" display="Site Name" datatype="string" default="">
      <join>JOIN cache_samples_nonfunctional snf ON snf.id=o.sample_id</join>
      <where>(snf.public_entered_sref='#site_name#' or o.location_name='#site_name#')</where>
    </param>
    <param name="region_id" display="Region" datatype="integer" default="">
      <where>#region_id# = ANY(o.location_ids)</where>
    </param>
  </params>
  <columns>
    <column name="host_plant" sql="mt.host_plants" display="Host Plant" in_count="true" />
    <column name="occurrence_count" sql="COUNT(DISTINCT o.id)" display="Occurrence count" aggregate="true" />
    <column name="species_count" sql="COUNT(DISTINCT o.taxon_meaning_id)" display="Taxon count" aggregate="true" />
  </columns>
</report>